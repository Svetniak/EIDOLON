extends CharacterBody2D

var bullet = preload("res://scenes/shot.tscn")

@onready var animated_sprite = $AnimatedSprite2D
@onready var nozzle : Marker2D = $Nozzle

@export var walk_speed = 300.0
@export var run_speed = 400.0
@export var jump_force = -400.0
@export_range(0, 1) var decelerate_on_jump_release = 0.5
@export_range(0, 1) var acceleration = 0.1
@export_range(0, 1) var deceleration = 0.1

@export var dash_speed = 1000.0
@export var dash_max_distance = 300.0
@export var dash_curve : Curve
@export var dash_cooldown = 1.0
@export var wall_slide_divider = 0.2

var jumps_left = 2

var is_dashing: bool = false
var dash_start_position = 0
var dash_direction = 0
var dash_timer = 0

var nozzle_position


func _physics_process(delta: float) -> void:
	var direction = Input.get_axis("move_left", "move_right")

	if not is_on_floor():
		velocity += get_gravity() * delta

	if is_on_wall() and not is_on_floor() and velocity.y > 0:
		var wall_slide = get_gravity() * wall_slide_divider

		animated_sprite.play("on_wall")
		velocity = wall_slide

	if Input.is_action_just_pressed("jump") and jumps_left > 0:
		jumps_left -= 1
		velocity.y = jump_force


	# Flip sprite
	if direction > 0:
		animated_sprite.flip_h = false
	elif direction < 0:
		animated_sprite.flip_h = true

	# Jump
	if is_on_floor():
		if direction == 0:
			animated_sprite.play("idle_1")
		else:
			animated_sprite.play("walk")
	else:
		animated_sprite.play("jump")

	if Input.is_action_just_released("jump") and velocity.y < 0:
		velocity.y *= decelerate_on_jump_release

	if Input.is_action_just_pressed("jump") and is_on_wall():
		animated_sprite.play("wall_jump")

	if is_on_floor() or is_on_wall():
		jumps_left = 2

	# Movement
	var speed
	speed = walk_speed

	if direction:
		velocity.x = direction * walk_speed
		velocity.x = move_toward(velocity.x, direction * speed, speed * acceleration)
	else:
		velocity.x = move_toward(velocity.x, 0, walk_speed * deceleration)

	# Shooting
	if Input.is_action_just_pressed("shoot") and direction != 0:
		nozzle_position = nozzle.position

		if direction > 0:
			nozzle.position.x = nozzle_position.x
		elif direction < 0:
			nozzle.position.x = -nozzle_position.x

		var bullet_instance = bullet.instantiate() as Node2D

		bullet_instance.direction = direction
		bullet_instance.global_position = nozzle.global_position
		get_parent().add_child(bullet_instance)
		animated_sprite.play("shoot_run")

	# Dash
	if Input.is_action_just_pressed("dash") and direction and not is_dashing and dash_timer <= 0:
		is_dashing = true
		dash_start_position = position.x
		dash_direction = direction
		dash_timer = dash_cooldown

	if is_dashing:
		var current_distance = abs(position.x - dash_start_position)
		animated_sprite.play("dash")

		if current_distance >= dash_max_distance or is_on_wall():
			is_dashing = false
		else:
			velocity.x = dash_direction * dash_speed * dash_curve.sample(current_distance / dash_max_distance)
			velocity.y = 0

	if dash_timer > 0:
		dash_timer -= delta

	print(direction)


	move_and_slide()
